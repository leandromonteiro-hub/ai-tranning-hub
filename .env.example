# ─────────────────────────────────────────────────────────────
# Athlete AI Training Hub — environment configuration
# Copy to .env and adjust. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- Environment ---
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# --- Security / Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-please-generate-a-32-byte-hex-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Rate limiting (requests per minute per authenticated user)
RATE_LIMIT_PER_MINUTE=120

# --- Garmin Connect sync (unofficial) ---
# Fernet key (base64) that encrypts Garmin tokens at rest.
# Empty = feature DISABLED (garmin routes return 503).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GARMIN_TOKEN_KEY=

# --- Google SSO ---
# OAuth Client ID (tipo Web) do Google Cloud Console. Vazio = SSO desligado.
# O MESMO valor vai no web como NEXT_PUBLIC_GOOGLE_CLIENT_ID (web/.env.local em dev).
GOOGLE_CLIENT_ID=

# --- PostgreSQL ---
POSTGRES_USER=athlete
POSTGRES_PASSWORD=athlete_dev_pwd
POSTGRES_DB=athlete_hub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async URL (used by the app). Sync URL is derived for Alembic.
DATABASE_URL=postgresql+asyncpg://athlete:athlete_dev_pwd@postgres:5432/athlete_hub

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- LLM provider abstraction ---
# Provider: anthropic | openai | local | mock
LLM_PROVIDER=mock
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Embeddings
EMBEDDING_PROVIDER=local           # mock | openai | local (local = fastembed, offline)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384                  # 384 for local/mock; 1536 if switching to openai

# --- Frontend (Streamlit) ---
STREAMLIT_API_BASE_URL=http://api:8000/api/v1

# --- Bootstrap admin (created on first startup if absent) ---
BOOTSTRAP_ADMIN_EMAIL=admin@athletehub.example.com
BOOTSTRAP_ADMIN_PASSWORD=admin_dev_pwd
